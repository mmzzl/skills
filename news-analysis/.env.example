# AI分析配置示例
# 复制此文件为 .env 并填入你的配置

# AI API配置
# 使用OpenAI API
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=your-openai-api-key-here
AI_MODEL=gpt-4o-mini

# 使用Azure OpenAI
# AI_API_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment/chat/completions?api-version=2024-02-15-preview
# AI_API_KEY=your-azure-key-here
# AI_MODEL=gpt-4

# 使用本地模型（如Ollama）
# AI_API_URL=http://localhost:11434/v1/chat/completions
# AI_API_KEY=ollama
# AI_MODEL=llama3

# 使用其他兼容OpenAI API的服务
# AI_API_URL=https://your-api-endpoint.com/v1/chat/completions
# AI_API_KEY=your-api-key-here
# AI_MODEL=your-model-name
